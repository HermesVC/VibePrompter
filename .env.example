# Environment Configuration
# Copy this file to .env.local and fill in your values
# Do NOT commit .env files with real values to version control

# =============================================================================
# Application
# =============================================================================
VITE_APP_NAME="My Application"
VITE_APP_VERSION="1.0.0"

# =============================================================================
# API Configuration
# =============================================================================
# Base URL for API requests
VITE_API_URL=http://localhost:5000/api

# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# =============================================================================
# Feature Flags
# =============================================================================
# Enable debug mode (extra logging, dev tools)
VITE_DEBUG_MODE=false

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# Enable service worker for offline support
VITE_ENABLE_SW=false

# =============================================================================
# Third-party Services (Add as needed)
# =============================================================================
# VITE_SENTRY_DSN=
# VITE_GA_TRACKING_ID=
# VITE_FIREBASE_API_KEY=

# =============================================================================
# Tauri updater signing — RELEASE BUILDS ONLY. Never commit real values.
# =============================================================================
# Path to the private key file generated by `tauri signer generate`. Set
# this in your CI environment (e.g. GitHub Actions repository secret) so
# `tauri build` can sign the release artifacts. Local dev builds skip
# signing — only release artifacts need it.
# TAURI_SIGNING_PRIVATE_KEY=/path/to/vibeprompter.key
#
# Password for the private key. Required only if you generated the key
# with a passphrase. Keep it as a separate CI secret, not in source.
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
